{
  "name": "agent-platform",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"cd packages/server && npx tsx src/index.ts\" \"cd packages/web && npx next dev -p 3004\"",
    "build": "pnpm -r build",
    "start": "node packages/server/dist/index.js"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild", "sharp", "unrs-resolver"]
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
