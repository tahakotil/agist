# Agist Configuration

# Auth (set to 'true' to disable auth for local dev)
AGIST_AUTH_DISABLED=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3004

# Logging
LOG_LEVEL=info

# Adapters (optional — only needed if using these adapters)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Integrations (optional)
SLACK_WEBHOOK_URL=
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# Run cleanup
RUN_TTL_DAYS=

# Server
PORT=4400
